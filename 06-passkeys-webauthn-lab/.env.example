# Relying Party — must match browser URL exactly
RP_NAME=FinFlow Passkeys Lab
RP_ID=localhost
ORIGIN=http://localhost:8002

# Lab scenario: happy | wrong_rp_id | wrong_origin | missing_assetlinks | bad_assetlinks
SCENARIO=happy

SESSION_SECRET=change-me-to-a-long-random-secret
DATABASE_PATH=./data/passkeys.db

# Android Digital Asset Links (used when SCENARIO=happy or bad_assetlinks)
ANDROID_PACKAGE_NAME=com.finflow.passkeys
ANDROID_SHA256_CERT_FINGERPRINTS=AB:CD:EF:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00
