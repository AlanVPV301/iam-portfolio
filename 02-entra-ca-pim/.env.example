# Copy to .env (gitignored) or export in your shell before Terraform / scripts.
# Never commit real values.

# Trusted IP for FinFlow-Trusted-IP-Locations (Terraform — CIDR notation)
TF_VAR_trusted_ip_cidr=203.0.113.10/32

# Optional — overrides tenant_id in terraform.tfvars
TF_VAR_tenant_id=your-tenant-id-here

# Test user passwords (PowerShell user/break-glass scripts)
FINFLOW_USER_PASSWORD=your-temp-password-here
FINFLOW_BREAKGLASS_PASSWORD=your-breakglass-password-here

# Terraform SP auth (Azure convention)
# ARM_TENANT_ID=
# ARM_CLIENT_ID=
# ARM_CLIENT_SECRET=
